#!/usr/bin/env bash
# jfrdoc CLI entry point.
# Resolves its own directory so the script works from any cwd, then
# invokes Java 25 source-file mode on jfrdoc.java with zsmith on the
# classpath. Sibling .java files (e.g. JfrSummaryTool.java) are picked
# up automatically by the multi-file source launcher (JEP 458).
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec java --source 25 --class-path "$DIR/lib/zsmith.jar" "$DIR/jfrdoc.java" "$@"
