#!/usr/bin/env bash
# jfrdoc CLI: Java 25 source-file mode on jfrdoc.java + sibling JfrXxxTool.java
# files (JEP 458), with lib/zsmith.jar on the classpath.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec java \
    -Dstdout.encoding=UTF-8 \
    -Dstderr.encoding=UTF-8 \
    -Djfrdoc.home="$DIR" \
    --source 25 --class-path "$DIR/lib/zsmith.jar" "$DIR/jfrdoc.java" "$@"
